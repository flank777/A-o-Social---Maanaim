# ===== Gemini (Google AI Studio - https://aistudio.google.com/apikey) =====
GEMINI_API_KEY=cole_sua_chave_aqui
GEMINI_MODEL=gemini-flash-latest

# ===== Firebase =====
# Caminho para o arquivo JSON da conta de serviço baixado no Firebase Console
# (Configurações do projeto > Contas de serviço > Gerar nova chave privada)
FIREBASE_CREDENTIALS=./serviceAccountKey.json

# ===== Dados da instituição (usados no prompt) =====
TELEFONE_PRINCIPAL=(91) 90000-0000

# ===== Telegram (opcional, para testar de graça) =====
# Crie um bot com o @BotFather no Telegram e cole o token aqui
TELEGRAM_TOKEN=

# Chat/grupo do Telegram onde a EQUIPE recebe os alertas de novos casos.
# Veja no README como descobrir esse ID.
TEAM_TELEGRAM_CHAT_ID=

# ===== WhatsApp (Evolution API - open-source, self-host, grátis) =====
EVOLUTION_URL=http://localhost:8080
EVOLUTION_API_KEY=cole_a_apikey_da_evolution
EVOLUTION_INSTANCE=dona_assuncao

# ===== CORS (widget do site público chama esta API direto do navegador) =====
# Domínio(s) autorizados a chamar /webhook, separados por vírgula.
# Em produção, troque "*" pelo domínio real do site (ex.: https://acaosocialsemear.org).
CORS_ORIGINS=*

# ===== Limite de abuso (protege o custo do Gemini contra flood) =====
RATE_LIMIT_MAX=12
RATE_LIMIT_WINDOW=60
